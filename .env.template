# ==============================================================================
#  Arcane Redux Dashboard — .env Template
#  Copy this file to: agent/.env  (then fill in your API keys)
# ==============================================================================

# -- LM Studio (Local LLM — FREE, no rate limits) ------------------------------
# Download LM Studio from https://lmstudio.ai
# Start the local server and load a model, then set the URL and model name below
LM_STUDIO_BASE_URL=http://10.206.96.37:1234/v1
LM_STUDIO_MODEL=nvidia/nemotron-3-nano-4b
LM_STUDIO_API_KEY=lm-studio

# -- Groq (FREE — 14,400 req/day) ----------------------------------------------
# Get your free key at: https://console.groq.com
GROQ_API_KEY=PASTE_YOUR_GROQ_KEY_HERE

# -- OpenRouter (FREE models available) ----------------------------------------
# Get your key at: https://openrouter.ai
OPENROUTER_API_KEY=PASTE_YOUR_OPENROUTER_KEY_HERE

# -- Anthropic / Claude (PAID) -------------------------------------------------
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=PASTE_YOUR_ANTHROPIC_KEY_HERE
CLAUDE_MODEL=claude-sonnet-4-6

# -- Google Gemini (FREE tier — 1,500 req/day) ---------------------------------
# Get your key at: https://aistudio.google.com
GEMINI_API_KEY=PASTE_YOUR_GEMINI_KEY_HERE
GEMINI_MODEL=gemini-2.0-flash

# -- OpenAI (PAID) -------------------------------------------------------------
OPENAI_API_KEY=PASTE_YOUR_OPENAI_KEY_HERE

# -- YouTube Data API v3 -------------------------------------------------------
# Create a project at https://console.cloud.google.com
# Enable YouTube Data API v3, create OAuth2 credentials
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_CHANNEL_ID=
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json
YOUTUBE_TOKEN_FILE=youtube_token.json

# -- Supabase ------------------------------------------------------------------
# Create a project at https://supabase.com (free tier available)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=PASTE_YOUR_SUPABASE_SERVICE_KEY_HERE

# -- Avatar APIs (optional) ----------------------------------------------------
# D-ID: https://www.d-id.com (free trial available)
DID_API_KEY=
DID_PRESENTER_IMAGE_URL=

# HeyGen: https://www.heygen.com (alternative avatar)
HEYGEN_API_KEY=

# -- Pexels (FREE stock footage) -----------------------------------------------
# Get your free key at: https://www.pexels.com/api/
PEXELS_API_KEY=

# -- ClickUp (optional — human approval workflow) ------------------------------
CLICKUP_API_KEY=
CLICKUP_LIST_ID=
CLICKUP_IDEAS_LIST_ID=
CLICKUP_CHAT_LIST_ID=

# -- Channel Settings ----------------------------------------------------------
CHANNEL_NICHE=AI & Automation
CHANNEL_TONE=educational, engaging, slightly provocative
AVATAR_NAME=Aria
AVATAR_VOICE=af_heart

# -- Publishing Schedule -------------------------------------------------------
VIDEOS_PER_WEEK=3
PUBLISH_DAYS=tue,thu,sat
PUBLISH_HOUR=15
SHORTS_PER_DAY=3
REQUIRE_APPROVAL=true

# -- Output directories (leave as defaults) ------------------------------------
OUTPUT_DIR=output
SCRIPTS_DIR=output/scripts
AUDIO_DIR=output/audio
VIDEOS_DIR=output/videos
THUMBNAILS_DIR=output/thumbnails
